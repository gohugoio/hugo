      "description": "https://gohugo.io/configuration/http-cache/#respect-cache-control-no-store-in-response"
    },
    "cache": {
      "properties": {
        "for": {
          "properties": {
            "excludes": {
              "items": {
                "type": "string"
              },
              "type": "array",
              "description": "https://gohugo.io/configuration/http-cache/#cacheforexcludes"
            },
            "includes": {
              "items": {
                "type": "string"
              },
              "type": "array",
              "description": "https://gohugo.io/configuration/http-cache/#cacheforincludes"
            }
          },
          "type": "object",
          "description": "https://gohugo.io/configuration/http-cache/#cachefor"
        }
      },
      "type": "object",
      "description": "https://gohugo.io/configuration/http-cache/#cache"
