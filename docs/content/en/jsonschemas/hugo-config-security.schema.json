    "allowContent": {
      "properties": {},
      "type": "object",
      "description": "https://gohugo.io/configuration/security/#allow-content"
    },
    "enableInlineShortcodes": {
      "type": "boolean",
      "description": "https://gohugo.io/configuration/security/#enableinlineshortcodes"
    }
