{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://gohugo.io/jsonschemas/hugo-config-imaging.schema.json",
  "properties": {
    "resampleFilter": {
      "type": "string",
      "description": "https://gohugo.io/configuration/imaging/#resamplefilter"
    },
    "anchor": {
      "type": "string",
      "description": "https://gohugo.io/configuration/imaging/#anchor"
    },
    "bgColor": {
      "type": "string",
      "description": "https://gohugo.io/configuration/imaging/#bgcolor"
    },
    "exif": {
      "properties": {
        "includeFields": {
          "type": "string",
          "description": "https://gohugo.io/configuration/imaging/#includefields"
        },
        "excludeFields": {
          "type": "string",
          "description": "https://gohugo.io/configuration/imaging/#excludefields"
        },
        "disableDate": {
          "type": "boolean",
          "description": "https://gohugo.io/configuration/imaging/#disabledate"
        },
        "disableLatLong": {
          "type": "boolean",
          "description": "https://gohugo.io/configuration/imaging/#disablelatlong"
        }
      },
      "type": "object",
      "description": "https://gohugo.io/configuration/imaging/#exif"
    },
    "meta": {
      "properties": {
        "fields": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "https://gohugo.io/configuration/imaging/#metafields"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "https://gohugo.io/configuration/imaging/#metasources"
        }
      },
      "type": "object",
      "description": "https://gohugo.io/configuration/imaging/#meta"
    },
    "jpeg": {
      "properties": {
        "quality": {
          "type": "integer",
          "description": "https://gohugo.io/configuration/imaging/#quality"
        }
      },
      "type": "object",
      "description": "https://gohugo.io/configuration/imaging/#jpeg"
    },
    "webp": {
      "properties": {
        "quality": {
          "type": "integer",
          "description": "https://gohugo.io/configuration/imaging/#quality"
        },
        "compression": {
          "type": "string",
          "description": "https://gohugo.io/configuration/imaging/#webpcompression"
        },
        "hint": {
          "type": "string",
          "description": "https://gohugo.io/configuration/imaging/#hint"
        },
        "useSharpYuv": {
          "type": "boolean",
          "description": "https://gohugo.io/configuration/imaging/#webpusesharpyuv"
        },
        "method": {
          "type": "integer",
          "description": "https://gohugo.io/configuration/imaging/#webpmethod"
        }
      },
      "type": "object",
      "description": "https://gohugo.io/configuration/imaging/#webp"
    },
    "avif": {
      "properties": {
        "quality": {
          "type": "integer",
          "description": "https://gohugo.io/configuration/imaging/#quality"
        },
        "compression": {
          "type": "string",
          "description": "https://gohugo.io/configuration/imaging/#avifcompression"
        },
        "hint": {
          "type": "string",
          "description": "https://gohugo.io/configuration/imaging/#hint"
        },
        "encoderSpeed": {
          "type": "integer",
          "description": "https://gohugo.io/configuration/imaging/#avifencoderspeed"
        }
      },
      "type": "object",
      "description": "https://gohugo.io/configuration/imaging/#avif"
    }
  },
  "type": "object"
}
